# ============================================================
# 환경 변수 템플릿
#
# 실제 값은 .env 에 채워넣고 커밋 금지 (.env* 는 gitignore).
# Prisma CLI 가 .env 만 읽으므로 .env.local 이 아닌 .env 권장.
# server-only — `NEXT_PUBLIC_` prefix 절대 금지.
# ============================================================


# ─── Supabase Auth + Storage (도입 예정) ──────────────────
# 현재는 미사용 — Auth (가입자 phone OTP / 설계사·운영자 로그인) 도입 시점에 활성.
# Dashboard → Project Settings → API

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# Secret key (sb_secret_…) — RLS bypass, 서버 코드 전용. service_role key 의 신 명칭.
SUPABASE_SECRET_KEY=


# ─── Prisma (Postgres) ────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string
#
# 무료 플랜은 "Direct connection" (db.<ref>.supabase.co:5432) 가 IPv4 유료.
# 둘 다 Supavisor pooler 호스트 (<region>.pooler.supabase.com) 의 다른 포트 사용.
#
# `?schema=claim` — Prisma 가 default schema 로 사용. `_prisma_migrations` 도
# 거기 생성. 도메인 테이블 (@@schema 명시) 외에 우리가 만드는 모든 obj 가 claim 으로 모임.

# 런타임 쿼리. "Transaction pooler" (port 6543)
# + `?pgbouncer=true&connection_limit=1&schema=claim`.
DATABASE_URL=

# `prisma migrate` / `db pull` 전용. "Session pooler" (port 5432) + `?schema=claim`.
# session-mode 라 advisory lock / DDL in tx 등 migrate 요구사항 충족.
DIRECT_URL=


# ─── AWS S3 (설계사 제안서 PDF) ───────────────────────────
# IAM 정책: dedicated user, `s3:PutObject`+`GetObject`+`HeadObject`+`DeleteObject` on
# `arn:aws:s3:::<bucket>/proposals/*` 만 허용.
# Bucket: 100% private (public access block), CORS PUT 메서드만 우리 도메인 허용.

# 한국 사용자 기준 ap-northeast-2 (서울) 권장.
AWS_REGION=ap-northeast-2

# 제안서 PDF 저장 버킷명 (account 안에서 unique).
S3_BUCKET_PROPOSALS=

# Dedicated IAM user credentials. Vercel env 에는 secret 으로 등록.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 업로드 한도 (byte). 기본 10MB.
PROPOSAL_PDF_MAX_BYTES=10485760
