# ============================================================
# 환경 변수 템플릿
#
# 실제 값은 .env 에 채워넣고 커밋 금지 (.env* 는 gitignore).
# Prisma CLI 가 .env 만 읽으므로 .env.local 이 아닌 .env 권장.
# server-only — `NEXT_PUBLIC_` prefix 절대 금지.
#
# 로컬 dev DB 는 worktree 별 Docker Postgres — `pnpm db:start` 가 자동 기동.
# DATABASE_URL / DIRECT_URL 은 .env.local 에 자동 생성되므로 .env 에 비워둘 것.
# 자세한 흐름: docs/worktree-workflow.md
# ============================================================


# ─── Supabase Auth ───────────────────────────────────────
# admin 로그인용 (`src/server/supabase.ts` 의 cookie-based 서버 클라이언트).
# Dashboard → Project Settings → API.
#
# DB 쿼리는 Prisma 가 직결로 처리. supabase-js 는 Auth flow (signIn / getUser
# / signOut) 전용. browser-side 쿼리 도입 시점에 `NEXT_PUBLIC_` 버전 추가 필요.

# Project URL (https://<ref>.supabase.co)
SUPABASE_URL=

# Publishable key (sb_publishable_…) — anon key 의 신 명칭. RLS 적용 받음.
SUPABASE_PUBLISHABLE_KEY=

# Kakao OAuth `redirectTo` 는 요청 헤더 (`Origin` > `x-forwarded-*` > `host`)
# 로 base URL 추론 — `src/server/origin.ts` 참고. 환경별 env 변수 없음.
#
# **운영 측 필수 설정**: 사용자가 접근하는 모든 호스트 (prod / staging / LAN IP /
# ngrok 등) 를 Supabase Dashboard → Authentication → URL Configuration 의
# **Redirect URLs** 에 추가. 누락 시 Supabase 가 redirectTo 무시하고 Site URL
# (보통 localhost) 로 fallback. Site URL 도 운영 도메인으로 변경 권장.


# ─── Admin URL obfuscation (defense in depth) ────────────
# /admin/* 를 봇 스캐너로부터 숨김. **보안이 아니라 obscurity** — 코드 유출 시
# 무력화되므로 MFA / IP 화이트리스트 등과 병행 권장.
#
# 동작:
#   1. /<KNOCK_PATH> 진입 → admin_knock 쿠키 (30일, path=/admin, httpOnly) 발급
#      + /admin/login 으로 307 redirect
#   2. /admin/* 요청은 유효한 admin_knock 쿠키가 있을 때만 통과, 그 외엔 404
#      (admin 존재 자체를 부정)
#
# 미설정 시 knock 검사 스킵 — dev/staging 편의. **production 에는 반드시 설정**.
# 회전: 값 변경 + 재배포하면 기존 쿠키 무효화 (cookie value 가 ENV 와 비교됨).
# matcher 가 빌드 타임 baked-in 이라 ENV 변경은 재빌드 필요.
#
# 형식 권장: 추측 불가한 16+자 + 일반 URL 패턴과 다른 prefix (`__`, `_`, 등) —
# 우연한 일치/충돌 방지.
# 예: __ops-7x9k2m4hQ3
ADMIN_KNOCK_PATH=


# ─── Prisma (Postgres) ────────────────────────────────────
#
# 로컬 dev: 비워둘 것. `pnpm db:start` 가 worktree-별 Docker postgres 의 포트로
#   .env.local 에 자동 생성 — .env.local 이 .env 를 오버라이드 (Next.js 우선순위).
#   양쪽 URL 은 동일 (로컬은 pooler 없음, pgbouncer 옵션도 제거).
#
# Vercel / staging / prod: 아래 두 값을 Vercel env 에 설정.
#   - DATABASE_URL: "Transaction pooler" (port 6543)
#     + `?pgbouncer=true&connection_limit=1&schema=claim`
#   - DIRECT_URL:   "Session pooler" (port 5432) + `?schema=claim`
#     (`prisma migrate` / `db pull` 전용 — advisory lock / DDL in tx 필요)
#
# `?schema=claim` — Prisma default schema. `_prisma_migrations` 도 claim 에 생성.
DATABASE_URL=
DIRECT_URL=


# ─── Redis (OTP 코드 + IP 레이트리밋) ─────────────────────
# 설계 요청서 / partner 가입 본인인증 단계에서 발급 코드(TTL 180s)와 발송 시도
# IP 카운터를 저장. `src/server/redis.ts` 의 어댑터가 env 로 백엔드 자동 선택:
#   - UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN 있음 → Upstash REST (HTTP).
#     serverless (Vercel) 권장 — TCP lifecycle 문제 없음. 둘 중 하나만 있으면 invalid.
#   - 없음 → ioredis (TCP), REDIS_URL 사용.
#
# 로컬 dev: 비워둘 것 (UPSTASH 두 줄 + REDIS_URL 모두). `pnpm workspace:setup` 이
#   worktree-별 Docker redis 포트로 REDIS_URL 을 .env.local 에 자동 생성 → ioredis 어댑터.
# Vercel / staging / prod: Upstash 콘솔의 "REST API" 섹션에서 UPSTASH_REDIS_REST_URL
#   (`https://...upstash.io`) + UPSTASH_REDIS_REST_TOKEN 복사. REDIS_URL 은 비움.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=


# ─── 알리고 SMS (설계 요청서 본인인증) ─────────────────────
# https://smartsms.aligo.in/admin/api/spec.html
#
# `/request/[id]/confirm` 의 휴대폰 인증번호 발송 게이트웨이.
# 발신번호(ALIGO_SENDER) 는 알리고 콘솔에 사전 등록된 번호여야 발송 가능.
#
# 로컬 dev: ALIGO_TEST_MODE=Y 권장 — 실 SMS 미발송 + 코드 "000000" 고정.
#           이때 ALIGO_KEY/USER_ID/SENDER 미설정이어도 sendOtp 가 통과.
# Vercel / staging / prod: ALIGO_TEST_MODE=N + 실제 자격 입력. 모든 값 필수.

ALIGO_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=

# Y → 실 SMS 미발송 + 코드 "000000" 고정 (dev/test 편의).
# N → 실 SMS 발송 + 6자리 랜덤 코드 (prod).
ALIGO_TEST_MODE=Y

# ─── 알리고 IP 화이트리스트 우회 프록시 (선택) ─────────────
# 알리고는 발신 IP 화이트리스트를 요구하는데 Vercel egress 가 동적이라 직접 호출 불가.
# `infra/aligo-proxy/` 의 Lightsail 고정 IP 프록시를 거치게 하려면 두 값 설정.
#
# - ALIGO_PROXY_URL    : `terraform output -raw proxy_url` 값 (https://...)
# - ALIGO_PROXY_SECRET : `terraform output -raw shared_secret` 값
#
# 로컬 dev: 비워둘 것 (test mode 가 알리고 호출 자체를 스킵).
# Vercel: 둘 다 설정. URL 만 설정하고 SECRET 누락하면 EnvSchema 에서 throw.
ALIGO_PROXY_URL=
ALIGO_PROXY_SECRET=

# ─── OTP 발송 레이트리밋 토글 (선택) ───────────────────────
# 마케팅 요청서 (`features/requests/actions.ts:sendOtp`) + 파트너 가입
# (`app/partner/signup/[token]/actions.ts:requestPartnerSignupOtp`) 모두 IP 별 1시간 5회
# 윈도우로 OTP 발송 시도 제한 — Redis 키 `otp:rl:{ip}` 공유.
#
# Y → rate limit 카운터 자체를 건드리지 않음. load test / 스테이징 디버깅 / 본인 IP
#     로 반복 검증 시 편의.
# 미설정 또는 그 외 값 → default 동작 (rate limit on). prod 는 비워둘 것.
OTP_RATE_LIMIT_DISABLED=


# ─── 서비스 표시 이름 ─────────────────────────────────────
# 사용자 노출 문구에 박히는 서비스명 — SMS 본문 prefix `[<SERVICE_NAME>] ...`,
# 이메일 / 알림톡 등 추후 다른 채널 문구에서도 재사용.
# 예: "Claim" → `[Claim] 본인확인을 위해 인증번호 [123456]를 입력해주세요`
SERVICE_NAME=


# ─── 사용자 노출 base URL ─────────────────────────────────
# 외부 노출 절대 URL (Kakao OAuth redirectTo / SMS LMS 본문 링크 / PortOne redirect /
# 어드민 가입 안내 URL) 의 canonical host. trailing slash 없이 scheme + host[:port].
#
# 미설정 시 요청 헤더 (Origin > x-forwarded-host > host) 폴백 — 로컬 dev / LAN IP /
# ngrok 편의용. prod / staging 에선 반드시 설정.
#
# Vercel branch deployment 에 custom alias 를 붙인 경우 (예: dev.claim.ac →
# claim-web-env-staging-*.vercel.app) 가 가장 중요한 사용처: 사용자가 vercel.app
# URL 로 들어왔거나 webhook 이 vercel.app 로 도착해도 모든 외부 URL 이 alias 로 통일.
#
# 예: `PUBLIC_BASE_URL=https://dev.claim.ac` / `https://claim.ac`
PUBLIC_BASE_URL=


# ─── 로컬 Seed (Docker dev DB 전용) ───────────────────────
# `pnpm db:start` 의 seed step 에서 claim.admin_users 에 본인 row 자동 upsert.
# UUID 는 원격 dev Supabase project 의 본인 auth.users.id —
#   Supabase Dashboard → Authentication → Users → 본인 row → ID 컬럼 (UUID) 복사.
# 미설정 시 seed 가 warn 만 하고 통과. /admin 진입 시 화이트리스트 통과 못 함.
LOCAL_DEV_ADMIN_USER_ID=
LOCAL_DEV_ADMIN_EMAIL=


# ─── Partner 가입 초청 ────────────────────────────────────
# `/admin/partners/new` 에서 발급되는 partner_invitation token 의 만료 시한 (일).
# 재발급 (`reissuePartnerInvitationToken`) 시에도 동일 TTL 로 expiresAt 갱신.
# 미설정 시 기본 7. 짧을수록 운영자가 자주 재발급 필요.
PARTNER_INVITATION_TTL_DAYS=7

# Dev seed 가 만드는 sample partner_invitation 의 phone/name override + 본인인증
# pre-verify 토글. 기본값으로 dev 가 /partner/signup/<고정 token> 으로 즉시 Kakao
# 가입 단계까지 갈 수 있게 pre-verified. 본인인증 placeholder UI 단계를 확인하려면
# SKIP_VERIFY=false 로 설정. PortOne 실 흐름 테스트는 실제 본인 휴대폰 입력 권장.
LOCAL_DEV_PARTNER_PHONE=
LOCAL_DEV_PARTNER_NAME=
LOCAL_DEV_PARTNER_SKIP_VERIFY=true


# ─── AWS S3 (설계사 제안서 PDF) ───────────────────────────
# IAM 정책: dedicated user, `s3:PutObject`+`GetObject`+`HeadObject`+`DeleteObject` on
# `arn:aws:s3:::<bucket>/proposals/*` 만 허용.
# Bucket: 100% private (public access block), CORS PUT 메서드만 우리 도메인 허용.

# 한국 사용자 기준 ap-northeast-2 (서울) 권장.
AWS_REGION=ap-northeast-2

# 제안서 PDF 저장 버킷명 (account 안에서 unique).
S3_BUCKET_PROPOSALS=

# Dedicated IAM user credentials. Vercel env 에는 secret 으로 등록.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 업로드 한도 (byte). 기본 10MB.
PROPOSAL_PDF_MAX_BYTES=10485760


# ─── AWS SQS (eightytwo_judge 분석 파이프라인 잡 큐) ──────
# 제안서 제출 직후 분석 잡 발행. AWS_REGION/ACCESS_KEY 는 위 S3 섹션과 공유.
# IAM 정책에 해당 큐 ARN 의 `sqs:SendMessage` 추가 필요.
# 메시지 페이로드: { request_id, graph: "proposal_analysis", input: { s3_key }, webhook: { url }, metadata: { proposal_id, plan_request_id } }
SQS_ANALYSIS_QUEUE_URL=


# ─── 분석 완료 웹훅 ──────────────────────────────────────
# eightytwo_judge 가 한 proposal 분석 종료 시 우리 라우트로 POST.
# 페이로드: { request_id, status: "succeeded"|"failed", result: <report>|null,
#   error: { code, message }|null, metadata: { proposal_id, plan_request_id },
#   duration_ms } + X-Signature 헤더.

# 우리 웹훅 endpoint 의 절대 URL — SQS 메시지의 webhook.url 로 들어감.
# dev: https://<ngrok-or-tunnel-host>/api/webhooks/eightytwo-judge-analysis
# prod: https://<prod-domain>/api/webhooks/eightytwo-judge-analysis
ANALYSIS_CALLBACK_URL=

# HMAC-SHA256 검증용 shared secret. eightytwo_judge 가 raw body 를 이 키로 HMAC,
# `X-Signature: sha256=<hex>` 헤더에 실어 보냄. 우리 라우트가 동일 계산 후 비교.
# 충분히 긴 random (예: `openssl rand -hex 32`).
ANALYSIS_WEBHOOK_SECRET=


# ─── Vercel Cron ──────────────────────────────────────────
# `vercel.json` 의 crons 항목이 schedule 마다 GET 호출 (자동으로 Authorization
# 헤더에 `Bearer ${CRON_SECRET}` 주입). 라우트는 `src/app/api/cron/<job>/route.ts`
# 가 Bearer 검증 후 실행. 미설정 시 모든 cron 요청이 401.
#
# 형식 권장: `openssl rand -hex 32` — 32 byte 랜덤. 로컬 dev 에선 비워둬도 무방
# (cron 호출 안 일어남). Vercel project env 에 등록하면 platform 이 자동으로 cron
# 요청 헤더에 주입.
CRON_SECRET=


# ─── 마케팅 외부 링크 ─────────────────────────────────────
# 랜딩 footer "설계사이신가요?" 링크 목적지.
# 별도 가입 폼 (Google Form 등) URL. 비워두면 footer 링크가 렌더링되지 않음.
AGENT_SIGNUP_URL=


# ─── PortOne v2 결제 (파트너 크레딧 충전) ─────────────────
# `features/credits` 의 PaymentProvider 가 자동 선택:
#   - CREDIT_PAYMENT_PROVIDER=portone → 아래 4종 키 필수 (lazy validate)
#   - 그 외 / 미설정                 → Stub (NODE_ENV=production 진입 시 fail-closed)
#
# 콘솔: https://admin.portone.io
#   - [결제 연동] → 식별코드/API Keys → storeId / channelKey / V2 API Secret
#   - [결제 연동] → [결제알림(Webhook) 관리] → 웹훅 등록 + 시크릿 발급
#     ⚠️ 필수 설정:
#       · 웹훅 버전: "결제모듈 V2"  ← 2024-04-25 페이로드 자동 적용. server-sdk Webhook.verify 가
#                                   이 버전 전용 — 다른 버전 선택 시 우리 라우트가 invalid_signature 로 거부.
#       · Content Type: application/json
#       · Endpoint URL: https://<prod-domain>/api/webhooks/credits/portone
#         (dev 는 noticeUrls 로 동적 지정되므로 dummy 가능. 단 시크릿 발급을 위해 항목 1개는 등록 필요.)
#
# 환경 분리는 콘솔의 "테스트/실연동" 채널키로 — 코드 분기 없음.
#
# Vercel 등 prod 에선 webhook URL 이 noticeUrls 로 동적 지정되므로 콘솔 등록은 보조 (URL 만 덮어씀,
# 버전은 콘솔 설정 따름). dev 에서 PortOne 흐름 테스트 시는 ngrok/cloudflared 로 외부 노출 필요.
CREDIT_PAYMENT_PROVIDER=stub

PORTONE_STORE_ID=
PORTONE_CHANNEL_KEY=
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=
