// ============================================================
// Prisma schema — partner-match-mvp
//
// 진실 공급원 (DB 구조). features/<x>/schema.ts 의 zod 와 짝.
//   - zod    → 앱 레이어 입력/형식 검증 (value/range/format)
//   - prisma → DB 구조 무결성 (PK / FK / NOT NULL / UNIQUE / 인덱스)
//
// 명명 규칙:
//   - 모델 = PascalCase (TS 클라이언트 친화).
//   - 컬럼 DB 이름 = snake_case (`@map`). 모든 모델에 `@@map` 으로 테이블명 매핑.
//   - PK 는 `String @id` — 앱-사이드 nanoid(16) (`src/lib/id.ts` 의 `newId()`)
//     로 INSERT 전 생성. **DB DEFAULT 없음**. CUID/UUID 디폴트도 쓰지 않음.
//
// updated_at 정책: Prisma 의 `@updatedAt` 가 INSERT / UPDATE 시 timestamp 설정.
// DB 트리거는 사용 안 함 — 모든 시점 컨트롤은 앱 레이어 (Prisma client) 가 책임.
//
// DB 레벨 제약 최소화: CHECK / partial unique index 사용 안 함. 단일 row 강제
// (app_settings), race-safe 중복 차단 (phone-active, result_token) 같은 도메인
// 규칙은 모두 features/<x>/{queries,actions}.ts 가 책임.
//
// 스키마 분리: 모든 도메인 테이블 + `_prisma_migrations` 모두 `claim` 스키마.
// (DATABASE_URL 의 `?schema=claim` 로 default 가 claim → Prisma 가 그 안에 둠.)
// `schemas` 배열에 `public` 을 넣지 말 것 — `prisma migrate reset` 이 namespace
// 마다 `DROP SCHEMA … CASCADE` 를 도는데, Supabase `public` 은 extension
// (pg_graphql / pg_net / supabase_realtime 등) 들이 살아서 drop 권한 없음 +
// 강제 drop 시 프로젝트가 깨짐.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // Supavisor transaction pooler (6543)
  directUrl = env("DIRECT_URL")          // 직결 (5432) — migrate / introspect 용
  schemas   = ["claim"]
}

// ============================================================
// plan_request — 가입자 제안서 요청서
// ============================================================

model PlanRequest {
  id String @id

  // Step1: 요청서 본체 (gender 는 Step3 finalize 에서 주민번호로 set)
  gender             String?
  occupation         String
  monthlyBudgetMin   Int    @map("monthly_budget_min")
  monthlyBudgetMax   Int    @map("monthly_budget_max")

  // CoverageRequest discriminated union (broad | focused) — zod 검증 후 jsonb.
  coverage           Json
  additionalNotes    String? @map("additional_notes")

  // Step3: 본인 인증 (1:1 sparse — 인증 완료 시 채워짐)
  name               String?
  phone              String?
  // 주민번호 앞6자리+뒤1자리 → birth_date + gender(=Step1 gender) derive 후 폐기.
  // 원본 RRN 은 어디에도 저장하지 않음 (개인정보 최소화).
  birthDate          DateTime? @db.Date @map("birth_date")
  consentThirdParty  Boolean @default(false) @map("consent_third_party")
  consentMessaging   Boolean @default(false) @map("consent_messaging")

  // 워크플로우
  status        String  @default("selecting")
  rematchCount  Int     @default(0)     @map("rematch_count")
  resultToken   String? @map("result_token")

  // 시점
  createdAt     DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  dispatchedAt  DateTime? @db.Timestamptz(6) @map("dispatched_at")
  deadlineAt    DateTime? @db.Timestamptz(6) @map("deadline_at")
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz(6) @map("updated_at")

  medicalHistory PlanRequestMedicalHistory[]
  candidates     PlanRequestCandidate[]
  assignments    MatchAssignment[]

  @@index([status, createdAt(sort: Desc)])
  @@map("plan_request")
  @@schema("claim")
}

// ============================================================
// plan_request_medical_history — 병력 (1:N)
// ============================================================

model PlanRequestMedicalHistory {
  id String @id

  requestId            String   @map("request_id")
  diagnosis            String
  treatmentPeriod      String   @map("treatment_period")
  treatmentStartDate   DateTime @db.Date @map("treatment_start_date")
  hospitalizationDays  Int      @default(0) @map("hospitalization_days")
  outpatientVisits     Int      @default(0) @map("outpatient_visits")
  hadSurgery           Boolean  @default(false) @map("had_surgery")
  position             Int

  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  request PlanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, position])
  @@index([requestId])
  @@map("plan_request_medical_history")
  @@schema("claim")
}

// ============================================================
// plan_request_candidate — 후보/선택 (M:N junction)
// ============================================================

model PlanRequestCandidate {
  requestId      String   @map("request_id")
  partnerId      String   @map("partner_id")
  candidateRank  Int      @map("candidate_rank")
  selected       Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  request PlanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partner Partner     @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  @@id([requestId, partnerId])
  @@unique([requestId, candidateRank])
  @@index([requestId])
  @@index([partnerId])
  @@map("plan_request_candidate")
  @@schema("claim")
}

// ============================================================
// user — 모든 인증 사용자의 공통 정보
// ============================================================
// Supabase auth.users 와 1:1. id 는 도메인 nanoid (다른 테이블 FK 가 참조), authId
// 는 auth.users.id (UUID) 와 매핑되는 별도 인증 key.
//
// 사용자 생성 흐름:
//   1. 운영자가 사전 등록 — User row 생성 (authId=null, role/role 별 extension row).
//   2. 첫 로그인 (admin: 비번 / partner: kakao OAuth) 시 callback/action 이 email 로
//      User row 를 찾아 authId 채움 (claim). 이후 로그인은 authId 로 직접 lookup.
//
// role 은 빠른 분기용 discriminator. 실제 권한 검증은 partner/admin extension row
// 존재 여부로 (defense in depth) — DAL 이 둘 다 확인.

model User {
  id        String   @id                                  // nanoid(16) — 도메인 식별자
  authId    String?  @unique @db.Uuid @map("auth_id")     // = auth.users.id (UUID). 사전 등록 시 null, 첫 로그인 후 claim.
  email     String   @unique
  name      String
  phone     String?
  role      String                                        // "general" | "partner" | "admin"

  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6) @map("updated_at")

  partner   Partner?
  admin     Admin?

  @@index([role])
  @@map("user")
  @@schema("claim")
}

// ============================================================
// partner — 설계사 추가 정보 (User 와 1:1, PK 공유)
// ============================================================
// 가입자 노출:  user.name, avatarUrl, bio, yearsOfExperience, trustMetric
// 매칭 가중치: exposureCount (형평성), recentSubmissions (페널티)
// 운영:        user.email (로그인), user.phone (알림톡), active
//
// id 는 User.id 와 동일 — 1:1 extension. match_assignment / plan_request_candidate
// 의 partnerId 는 이 id (= User.id) 를 참조.

model Partner {
  id                 String   @id                          // = User.id (공유 nanoid)

  avatarUrl          String   @map("avatar_url")
  bio                String
  yearsOfExperience  Int      @map("years_of_experience")
  trustMetric        String   @map("trust_metric")
  /// 설계사 자격번호 — 운영자가 등록 시 기입. UNIQUE 제약으로 중복 등록 차단.
  licenseNumber      String   @unique @map("license_number")
  active             Boolean  @default(true)

  // 매칭 가중치
  exposureCount      Int       @default(0) @map("exposure_count")
  // recent_submissions[N] — 최근 N 건의 제출 이력 (true=제출, false=미제출).
  // 페널티 윈도우 안에서 미제출률 = (false 개수) / length. 앱 레이어가 push/trim.
  recentSubmissions  Boolean[] @default([]) @map("recent_submissions")

  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6) @map("updated_at")

  user        User                   @relation(fields: [id], references: [id], onDelete: Cascade)
  candidates  PlanRequestCandidate[]
  assignments MatchAssignment[]

  // 매칭 후보 추출 — active=true 중 exposure_count 적은 순으로 정렬.
  @@index([active, exposureCount])
  @@map("partner")
  @@schema("claim")
}

// ============================================================
// match_assignment — 요청 × 설계사 1:1 슬롯
// ============================================================
// 가입자가 선택한 설계사 K명 각각에 대해 1 row. 알림톡 진입 시 일회용 token 으로
// 인증. 설계사가 폼 제출하면 status='submitted' + proposal 1:1 생성.
//
// (request_id, partner_id) UNIQUE — 한 요청은 한 설계사에게 한 번만 송부.
// status 는 enum 대신 text — PRD 에서 상태 추가 가능성 (`declined` 등) 대비.

model MatchAssignment {
  id        String @id

  requestId String @map("request_id")
  partnerId String @map("partner_id")

  /// 알림톡 URL 진입용 일회성 토큰. nanoid(32) (newToken).
  token     String @unique

  status    String @default("pending")

  createdAt   DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  submittedAt DateTime? @db.Timestamptz(6) @map("submitted_at")

  request  PlanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partner  Partner     @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  proposal Proposal?

  @@unique([requestId, partnerId])
  @@index([requestId])
  @@index([partnerId, status])
  @@map("match_assignment")
  @@schema("claim")
}

// ============================================================
// proposal — 설계사 제출 제안서 (assignment 와 1:1)
// ============================================================
// 정형 필드 (보험료, 담보, 갱신/환급) 는 AI 가 PDF 에서 파싱하므로 입력 받지 않음.
// 설계사는 진설계 PDF (S3 저장) + 100자 한줄 요약만 작성.

model Proposal {
  id           String @id
  assignmentId String @unique @map("assignment_id")

  /// S3 object key — "proposals/{assignment_id}/{nanoid}.pdf". presigned URL 로 업로드 후 저장.
  pdfS3Key     String  @map("pdf_s3_key")
  /// HEAD 검증 시점 capture. 표시·집계용. null 허용.
  pdfSizeBytes BigInt? @map("pdf_size_bytes")

  /// PDF 본문의 SHA-256 (hex, 64자). 업로드 직후 항상 채워짐. 동일 PDF 식별/audit
  /// 용도 — 분석 리포트 join 키는 proposal.id 사용 (`ProposalAnalysisReport` 1:1).
  pdfHash      String  @map("pdf_hash")

  /// 100자 한줄 요약 — 가입자 결과 페이지 말풍선에 그대로 노출 (verbatim).
  note String

  submittedAt DateTime  @default(now()) @db.Timestamptz(6) @map("submitted_at")
  /// 외부 분석 파이프라인 (eightytwo_judge) 콜백 수신 시각.
  /// 첫 콜백 시점만 기록 (WHERE analyzed_at IS NULL 로 update 한정 → 재시도 시 no-op).
  /// plan_request 의 모든 match_assignment 가 submitted + 그 proposal 이
  /// analyzed_at IS NOT NULL 인 경우에만 plan_request.status='completed'
  /// (pending/expired assignment 가 하나라도 있으면 전이 안 함).
  /// SQS 메시지 metadata 에 proposal.id + plan_request.id 를 실어보내고, 콜백이 그
  /// 두 id 로 직접 식별 + 마킹 (cross-validation 으로 페이로드 위조 차단).
  analyzedAt  DateTime? @db.Timestamptz(6) @map("analyzed_at")

  /// 외부 분석 파이프라인이 returned `status=failed` 시 마지막 실패 payload.
  /// `{ group: "input_error"|"product_id_match"|"internal_error", type, message, detail? }`.
  /// 어드민이 group=product_id_match 등 수기 대응 필요한 케이스를 인지하는 용도.
  /// 분석 성공 (analyzedAt 채워질 때) 시점에 명시적으로 null 초기화하진 않음 —
  /// 어차피 read 측은 analyzedAt 으로 우선 분기. 재시도 (retryProposalAnalysis)
  /// 시점에 두 컬럼 모두 null 로 초기화.
  analysisError   Json?     @map("analysis_error")
  analysisErrorAt DateTime? @db.Timestamptz(6) @map("analysis_error_at")

  assignment     MatchAssignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  analysisReport ProposalAnalysisReport?

  @@index([pdfHash])
  /// 어드민 "분석 실패" 뷰 — analyzedAt IS NULL AND analysisErrorAt IS NOT NULL
  /// 조건 스캔이 작은 테이블이지만 자주 호출되므로 보조 인덱스.
  @@index([analysisErrorAt])
  @@map("proposal")
  @@schema("claim")
}

// ============================================================
// proposal_analysis_report — 외부 분석 파이프라인 (eightytwo_judge) 결과
// ============================================================
// 웹훅 (/api/webhooks/eightytwo-judge-analysis) 이 분석 완료 콜백 수신 시 INSERT.
// proposal 과 1:1 (`proposal_id` PK + FK). SQS metadata 로 보낸 proposal.id 가
// 콜백에 그대로 passthrough 되어 식별 키로 사용됨.
//
// 버전 정책: 매 schema 진화 시 row 교체 운영 (`schemaVersion` 컬럼 + 읽을 때
// `CURRENT_REPORT_VERSION` 필터). v6 도입 시 새 row 가 v6 로 들어오고, 코드의
// `analysis-schema.ts` zod + `CURRENT_REPORT_VERSION` 갱신.

model ProposalAnalysisReport {
  proposalId    String @id @map("proposal_id")

  /// 리포트 schema 버전 (현재 5). 읽을 때 `WHERE schema_version = CURRENT_REPORT_VERSION` 로 gate.
  schemaVersion Int    @map("schema_version")

  /// AnalysisReportV5 (zod) 의 직렬화. Prisma 가 Json 으로 들고, 읽을 때 parse() 통과.
  /// `schema_version` 은 본문에 들어가지 않음 (별도 컬럼) — 웹훅이 분리 저장.
  report        Json

  /// 분석 소요 시간 (ms). 운영 모니터링용. null 허용.
  durationMs    Int?   @map("duration_ms")

  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([schemaVersion])
  @@map("proposal_analysis_report")
  @@schema("claim")
}

// ============================================================
// app_settings — 운영 튜닝 값 (single row)
// ============================================================
// id 는 항상 'app' 한 row 만. CHECK constraint 로 single-row 강제 (migration SQL).
// admin 화면이 mutation → 모든 매칭 흐름이 이 값을 함수로 읽음 (cache 금지).

model AppSettings {
  id String @id @default("app")

  /// N — 가입자에게 노출할 후보 수
  candidateCount         Int @default(5)  @map("candidate_count")
  /// K — 가입자가 선택 가능한 최대 인원
  selectLimit            Int @default(3)  @map("select_limit")
  /// T — 설계사 제안서 제출 제한시간 (시간 단위)
  submissionDeadlineHours Int @default(48) @map("submission_deadline_hours")
  /// 미제출률 페널티 산정 윈도우 (최근 N건)
  penaltyWindow          Int @default(10) @map("penalty_window")

  /// 결과 페이지 보관 기간 (일). dispatchedAt + N일 경과 시 결과 토큰 만료.
  resultRetentionDays    Int @default(7)  @map("result_retention_days")

  /// 결과 페이지 시나리오 우선순위. category_payouts.category 값의 ordered array.
  /// 앞에서부터 top3 후보. 보장 없는 카테고리는 자동 스킵 후 다음으로 대체.
  /// 리스트에 없는 카테고리는 모달 "기타" 영역에 가나다순으로 노출.
  scenarioPriority       String[] @default([]) @map("scenario_priority")

  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@map("app_settings")
  @@schema("claim")
}

// ============================================================
// admin — 운영자 추가 정보 (User 와 1:1, PK 공유)
// ============================================================
// User.role='admin' + 이 row 가 존재해야 권한 부여 (defense in depth).
// 운영자 추가/제거는 운영 SQL 또는 admin 운영 UI 로 수동 — 자체 signup 흐름 없음.
// RBAC permissions 는 추후 컬럼 추가로 도입 예정 (현재는 active 만 체크).

model Admin {
  id          String   @id                                 // = User.id (공유 nanoid)
  active      Boolean  @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6) @map("updated_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("admin")
  @@schema("claim")
}
