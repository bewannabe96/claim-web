# ── 필수 ──────────────────────────────────────────────────────
# 버킷 namespace (용도 식별자). 최종 버킷명은 `<account_id>-<region>-<namespace>`
# 패턴으로 자동 조합 — AWS 권장 (충돌 방지 + audit 용이).
#
# 예: namespace = "claim-content-prod"
#     → 123456789012-ap-northeast-2-claim-content-prod
namespace = "claim-content-prod"

# ── 선택 ──────────────────────────────────────────────────────

# 환경 식별자 — 태그에만 사용. environment 구분은 namespace 에 박을 것.
# environment = "prod"

# 리전. default = ap-northeast-2 (Seoul).
# aws_region = "ap-northeast-2"

# 공개 GET 허용 prefix. default = ["partners/avatar/"].
# 새 컨텐츠 도메인 (예: 마케팅 배너) 추가 시 여기 prefix 추가 + 앱 키 컨벤션 동기.
# public_read_prefixes = ["partners/avatar/", "marketing/banner/"]

# 브라우저 origin 화이트리스트. prod 도메인 포함시킬 것.
# cors_allowed_origins = [
#   "https://claim.ac",
#   "https://*.vercel.app",
#   "http://localhost:3000",
# ]

# 기존 IAM user 재사용 (예: 제안서 버킷용 user 가 이미 있고 자격증명을 공유하려면).
# 빈 문자열 / 미설정 시 dedicated user 신규 생성 + access key outputs 로 노출.
# iam_user_name = "claim-web-s3-app"

# 미완료 multipart upload 자동 청소 (일). 0 이면 비활성.
# abort_incomplete_multipart_days = 1
